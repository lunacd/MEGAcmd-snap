From f2f65e837d2001ee565a46d21ee13e452b378bd4 Mon Sep 17 00:00:00 2001
From: Haowen Liu <liu.haowen.andy@gmail.com>
Date: Mon, 20 Jul 2026 20:06:14 -0400
Subject: [PATCH 2/3] Fix pkgconfig support for pcre

---
 build/cmake/modules/megacmd_libraries.cmake | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/build/cmake/modules/megacmd_libraries.cmake b/build/cmake/modules/megacmd_libraries.cmake
index aa3c2d73..7a6c8fb9 100644
--- a/build/cmake/modules/megacmd_libraries.cmake
+++ b/build/cmake/modules/megacmd_libraries.cmake
@@ -16,8 +16,8 @@ macro(load_megacmdserver_libraries)
         find_package(PkgConfig REQUIRED) # For libraries loaded using pkg-config
 
         if(USE_PCRE) #TODO: UNTESTED!
-            pkg_check_modules(pcre REQUIRED IMPORTED_TARGET libpcre)
-            target_link_libraries(LMegacmdServer PRIVATE PkgConfig::pcre)
+            pkg_check_modules(pcrecpp REQUIRED IMPORTED_TARGET libpcrecpp)
+            target_link_libraries(LMegacmdServer PRIVATE PkgConfig::pcrecpp)
             set(USE_PCRE 1)
         endif()
     endif()
-- 
